---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="mb-[20px] flex items-center gap-[12px]">
  <div class="h-[20px] w-[3px] rounded-full gradient-bar"></div>
  <h3 class="text-[12px] font-sans font-medium text-soft uppercase tracking-[0.15em]">
    {title}
  </h3>
  <div class="flex-1 h-[1px]" style="background: linear-gradient(90deg, rgba(124,58,237,0.15), transparent);"></div>
</div>
