---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="mb-[24px]">
  <div class="flex items-center gap-[12px]">
    <div class="h-[1px] flex-1 bg-fracture"></div>
    <h3 class="text-[10px] font-mono text-ash uppercase tracking-[0.22em] leading-none">
      {title}
    </h3>
    <div class="h-[1px] flex-1 bg-fracture"></div>
  </div>
</div>
