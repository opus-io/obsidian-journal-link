---
import { logoMap } from "../data/products";
interface Props { product: Product; index?: number; }
const { product, index = 0 } = Astro.props;
const isFeatured = product.variant === "featured";
const delay = index * 100 + 150;
function formatSold(val?: number): string {
  if (!val) return "";
  if (val >= 1000) return (val / 1000).toFixed(0) + "rb";
  return val.toString();
}
function getPlatformLogo(tag: string): string { return logoMap[tag.toUpperCase()] || ""; }
function getLogoForLink(label: string): { logo: string; tag: string } {
  const upper = label.toUpperCase();
  for (const tag of product.tags) { if (upper.includes(tag)) { return { logo: getPlatformLogo(tag), tag }; } }
  return { logo: "", tag: "" };
}
const standardStyle = "background:var(--nebula); border:0; border-radius:0;";
const featuredStyle = "background:var(--nebula); border:0; border-radius:0; box-shadow:0 0 40px rgba(91,33,182,0.2);";
---
<div class={`product-card cardIn`}
  style={`animation-delay:${delay}ms; ${isFeatured ? featuredStyle : standardStyle}; transition:background 0.3s;`}
  onmouseover="this.style.background='rgba(18,12,48,0.9)'" onmouseout="this.style.background='var(--nebula)'"
  data-url={product.defaultUrl} role="article">
  <div class={`flex items-start justify-between gap-[12px] ${isFeatured ? 'pl-0' : ''}`} style="padding:16px">
    <div class="fast-lane flex items-center gap-[12px] flex-1 cursor-pointer group/fast">
      <div class="shrink-0 overflow-hidden" style="box-shadow:0 0 8px rgba(91,33,182,0.06);">
        <img src={product.image} alt={product.imageAlt} loading="lazy" decoding="async" class="w-[52px] h-[52px] object-cover transition-opacity duration-300 group-hover/fast:opacity-70" />
      </div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-[8px] mb-[4px]">
          <span class="id-badge">{product.id}</span>
          {isFeatured && <span style="font-size:8px; color:#A855F7; letter-spacing:0.15em; font-family:Inter,sans-serif; text-transform:uppercase;">✦ unggulan</span>}
          <span style="font-size:9px; color:var(--muted); text-transform:uppercase; letter-spacing:0.12em; font-family:Inter,sans-serif;">{product.badge}</span>
        </div>
        <h2 style="font-size:15px; font-weight:600; color:var(--white); letter-spacing:-0.01em; line-height:1.3; font-family:Inter,system-ui,sans-serif; transition:color 0.3s;"
          class="group-hover/fast:text-[#7A3CEA]">{product.title}</h2>
        {(product.rating || product.sold) && (
          <div class="flex items-center gap-[8px] mt-[4px]">
            {product.rating && <span style="font-size:11px; color:var(--muted); font-family:Inter,sans-serif;">★ {product.rating}</span>}
            {product.sold && <span style="font-size:11px; color:var(--muted); font-family:Inter,sans-serif;">{formatSold(product.sold)} terjual</span>}
          </div>
        )}
        {product.shortDesc && <p style="font-size:11px; color:var(--muted); margin-top:3px; line-height:1.4; font-family:Inter,sans-serif;" class="line-clamp-1">{product.shortDesc}</p>}
        {product.tags.length > 0 && (
          <div class="flex gap-[4px] mt-[6px] flex-wrap">
            {product.tags.map((tag) => {
              const logoPath = getPlatformLogo(tag);
              return (
                <span class="tag">
                  {logoPath && <img src={logoPath} alt="" class="w-[9px] h-[9px] object-contain" loading="lazy" />}
                  {tag}
                </span>
              );
            })}
          </div>
        )}
      </div>
    </div>
    <button class="toggle-btn w-[26px] h-[26px] flex items-center justify-center shrink-0" style="background:rgba(91,33,182,0.04); border:0;" aria-label="Toggle details" aria-expanded="false">
      <svg class="w-[11px] h-[11px] transition-transform duration-300 arrow-icon" style="color:var(--muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
    </button>
  </div>
  {(product.description || product.links) && (
    <>
      <div class="separator" style="margin:0 16px;"></div>
      <div class="accordion-body">
        <div class="px-[16px] py-[12px]">
          {product.description && <p style="font-size:12px; color:var(--muted); line-height:1.6; font-family:Inter,sans-serif;">{product.description}</p>}
          {product.links && product.links.length > 0 && (
            <div class="flex flex-col gap-[8px] mt-[12px]">
              <span style="font-size:9px; color:var(--muted); text-transform:uppercase; letter-spacing:0.18em; font-family:Inter,sans-serif;">Tersedia di</span>
              <div class="flex gap-[8px] flex-wrap">
                {product.links.map((link) => {
                  const { logo, tag } = getLogoForLink(link.label);
                  return (
                    <a href={link.href}
                      style="display:flex; align-items:center; gap:8px; padding:8px 12px; font-size:11px; font-family:Inter,sans-serif; color:var(--muted); background:rgba(91,33,182,0.04); border:0; transition:all 0.3s;"
                      onmouseover="this.style.background='rgba(91,33,182,0.10)'; this.style.color='#fff'"
                      onmouseout="this.style.background='rgba(91,33,182,0.04)'; this.style.color='var(--muted)'">
                      {logo && <img src={logo} alt={tag} class="w-[12px] h-[12px] object-contain" loading="lazy" />}
                      {link.label.replace(/ACCESS \/\//, "").trim()}
                      <span style="color:#5B21B6; margin-left:4px;">↗</span>
                    </a>
                  );
                })}
              </div>
            </div>
          )}
        </div>
      </div>
    </>
  )}
  <button class="w-full px-[16px] py-[7px] text-[9px] text-left toggle-btn" style="color:var(--muted); text-transform:uppercase; letter-spacing:0.2em; font-family:Inter,sans-serif; background:transparent; border:0;" aria-label="Toggle details" aria-expanded="false">
    <span class="arrow transition-transform duration-300 inline-block mr-[5px]">▸</span>DETAILS
  </button>
</div>
<script>
function initCard() {
  document.querySelectorAll('.product-card').forEach(function(card) {
    var el = card, fast = card.querySelector('.fast-lane'), btns = card.querySelectorAll('.toggle-btn'), acc = card.querySelector('.accordion-body'), arr = card.querySelector('.arrow-icon'), url = card.getAttribute('data-url');
    if (!fast || !btns[0] || !acc || !arr || !url) return;
    var togg = function(e) {
      e.stopPropagation();
      if (el.classList.contains('is-open')) { el.classList.remove('is-open'); acc.style.maxHeight = '0px'; arr.classList.remove('rotate-180'); btns.forEach(function(b) { b.setAttribute('aria-expanded','false'); }); }
      else { el.classList.add('is-open'); acc.style.maxHeight = acc.scrollHeight + 'px'; arr.classList.add('rotate-180'); btns.forEach(function(b) { b.setAttribute('aria-expanded','true'); }); }
    };
    fast.addEventListener('click', function() { if (!el.classList.contains('is-open')) window.open(url,'_blank','noopener,noreferrer'); });
    btns.forEach(function(b) { b.addEventListener('click', togg); });
    el._cleanup = function() { fast.removeEventListener('click', null); btns.forEach(function(b) { b.removeEventListener('click', togg); }); };
  });
}
if (document.readyState==='loading') document.addEventListener('DOMContentLoaded',initCard);
else initCard();
</script>
