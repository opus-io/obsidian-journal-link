---
let diagnosticLines: string[] = [];
let diagnosticTags = [
  "VOL.01 // ENTRADA",
];
let tagInterval = 5000;
try {
  const config = await import("../../content/config.json", { assert: { type: "json" } });
  const cfg = config.default || config;
  if (cfg.diagnosticLines) diagnosticLines = cfg.diagnosticLines;
  if (cfg.diagnosticTags) diagnosticTags = cfg.diagnosticTags;
  if (cfg.tagInterval) tagInterval = cfg.tagInterval;
} catch {}

const linesJson = JSON.stringify(diagnosticLines);
const tagsJson = JSON.stringify(diagnosticTags);
---

<div
  class="absolute top-0 left-0 w-full h-[34vh] z-0 overflow-hidden"
  style="background: linear-gradient(135deg, #1A1A1A 0%, #201030 50%, #1A1A1A 100%); border-bottom: 1px solid rgba(124,58,237,0.15);"
  aria-hidden="true"
  data-lines={linesJson}
  data-tags={tagsJson}
  data-interval={tagInterval}
>
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 50% 100%, rgba(124,58,237,0.08) 0%, transparent 60%), radial-gradient(ellipse at 30% 20%, rgba(139,92,246,0.04) 0%, transparent 40%);"></div>
  <div class="absolute bottom-0 left-0 w-full h-[1px] pointer-events-none" style="background: linear-gradient(90deg, transparent, rgba(124,58,237,0.3), transparent);"></div>
  <div class="absolute inset-0 flex flex-col items-center justify-center px-[24px]">
    <div class="text-[12px] font-sans tracking-[0.18em] uppercase text-soft opacity-0" id="diagTag">
      VOL.01 // ENTRADA
    </div>
  </div>
  <div
    class="absolute bottom-0 left-0 w-full h-[60%] pointer-events-none"
    style="background: linear-gradient(to bottom, transparent, #1A1A1A);"
  >
  </div>
</div>

<script>
  function init() {
    var tagEl = document.getElementById('diagTag');
    if (!tagEl) return;
    setTimeout(function() {
      tagEl.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
      tagEl.style.opacity = '1';
    }, 300);
    var container = document.querySelector('[data-tags]');
    if (container) {
      var tags = JSON.parse(container.getAttribute('data-tags'));
      var interval = parseInt(container.getAttribute('data-interval'), 10) || 5000;
      if (tags && tags.length > 1) {
        var idx = 0;
        setInterval(function() {
          idx = (idx + 1) % tags.length;
          tagEl.style.opacity = '0';
          setTimeout(function() {
            tagEl.textContent = tags[idx];
            tagEl.style.opacity = '1';
          }, 500);
        }, interval);
      }
    }
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
